{
  "expo": {
    "name": "Conceptly",
    "slug": "conceptly",
    "scheme": "conceptly",
    "privacy": "public",
    "platforms": ["ios", "android", "web"],
    "version": "0.1.0",
    "orientation": "portrait",
    "jsEngine": "hermes",
    "assetBundlePatterns": ["**/*"],
    "plugins": ["expo-router"],
    "experiments": {
      "tsconfigPaths": true,
      "typedRoutes": true
    }
    ,
    "extra": {
      "useMockData": true
    }
  }
}
